#!/bin/bash

# Check if a branch name was provided
if [ -z "$1" ]; then
  echo "Usage: $0 <branch-name>"
  exit 1
fi

BRANCH="$1"

echo "Checking out and updating master..."
git checkout master
git pull

echo "Fetching the remote branch..."
git fetch origin "$BRANCH"

echo "Applying patch..."
BASE=$(git merge-base origin/master origin/"$BRANCH")
if ! git diff --binary "$BASE"..origin/"$BRANCH" | git apply --index --3way --verbose; then
  echo ""
  echo "ERROR: Failed to apply patch for branch '$BRANCH'"
  echo "Merge base: $BASE"
  echo ""
  echo "Files that failed to apply:"
  git diff --binary "$BASE"..origin/"$BRANCH" | git apply --check 2>&1 | grep "^error:" || true
  echo ""
  echo "This usually means the target files have diverged. You may need to resolve conflicts manually."
  exit 1
fi
